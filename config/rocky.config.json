{
  "version": 1,
  "daemon": {
    "listen": "0.0.0.0:7767",
    "hostnames": [
      "localhost",
      "127.0.0.1"
    ],
    "mcp": {
      "enabled": true,
      "injectIntoAgents": true
    }
  },
  "agents": {
    "providers": {
      "amaze": {
        "extends": "acp",
        "label": "Amaze",
        "command": [
          "bun",
          "__ROCKY_ROOT__/vendor/amaze/packages/coding-agent/src/cli.ts",
          "acp"
        ],
        "additionalModels": [
          {
            "id": "anthropic/claude-fable-5",
            "label": "Claude Fable 5",
            "isDefault": true,
            "thinkingOptions": [
              {
                "id": "medium",
                "label": "Medium",
                "isDefault": true
              },
              {
                "id": "high",
                "label": "High"
              }
            ]
          }
        ]
      }
    }
  }
}
