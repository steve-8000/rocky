{
  "type": "module",
  "private": true,
  "name": "@amaze/typescript-edit-benchmark",
  "version": "2.2.1",
  "description": "Edit benchmark suite using TypeScript source code mutations",
  "author": "Can Boluk",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/can1357/amaze.git",
    "directory": "packages/typescript-edit-benchmark"
  },
  "main": "./src/index.ts",
  "bin": {
    "typescript-edit-benchmark": "src/index.ts"
  },
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write .",
    "generate": "bun run src/generate.ts --typescript-dir /tmp/amaze-mono-source --count-per-type 4",
    "start": "bun run src/index.ts"
  },
  "dependencies": {
    "@babel/generator": "catalog:",
    "@babel/parser": "catalog:",
    "@babel/traverse": "catalog:",
    "@babel/types": "catalog:",
    "@amaze/agent-core": "workspace:*",
    "@amaze/coding-agent": "workspace:*",
    "@amaze/utils": "workspace:*",
    "diff": "catalog:",
    "prettier": "catalog:",
    "regexp-tree": "catalog:",
    "@amaze/ai": "workspace:*",
    "@amaze/tui": "workspace:*"
  },
  "devDependencies": {
    "@types/babel__generator": "catalog:",
    "@types/babel__traverse": "catalog:",
    "@types/bun": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  }
}
