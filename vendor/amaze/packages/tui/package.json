{
  "type": "module",
  "name": "@amaze/tui",
  "version": "2.2.1",
  "description": "Terminal User Interface library with differential rendering for efficient text-based applications",
  "author": "Can Boluk",
  "contributors": [
    "Mario Zechner"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/can1357/amaze.git",
    "directory": "packages/tui"
  },
  "keywords": [
    "tui",
    "terminal",
    "ui",
    "text-editor",
    "differential-rendering",
    "typescript",
    "cli"
  ],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "check": "biome check . && bun run check:types",
    "check:types": "tsgo -p tsconfig.json --noEmit",
    "lint": "biome lint .",
    "test": "bun test test/*.test.ts",
    "fix": "biome check --write --unsafe .",
    "fmt": "biome format --write ."
  },
  "dependencies": {
    "@amaze/natives": "workspace:*",
    "@amaze/utils": "workspace:*",
    "lru-cache": "catalog:",
    "marked": "catalog:"
  },
  "devDependencies": {
    "chalk": "catalog:",
    "@xterm/headless": "catalog:"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "files": [
    "src",
    "README.md",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "import": "./src/*.ts"
    },
    "./components/*": {
      "types": "./src/components/*.ts",
      "import": "./src/components/*.ts"
    },
    "./*.js": "./src/*.ts"
  }
}
