{
  "name": "rocky",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Rocky — self-contained agent orchestration platform: one process, one port, one UI",
  "scripts": {
    "setup": "sh scripts/setup.sh",
    "start": "sh scripts/rockyd.sh",
    "cli": "npm --prefix core run cli --silent --",
    "build:webui": "npm --prefix core/packages/app run build:web",
    "build:dmg": "npm --prefix core/packages/desktop run build",
    "icons": "python3 scripts/brand/make-icons.py .",
    "smoke": "sh scripts/smoke.sh"
  }
}
