{
  "name": "rocky",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "Rocky: amaze + Paseo + AionUi integrated into one self-contained server with remote WebUIs and a desktop app",
  "scripts": {
    "setup": "sh scripts/setup.sh",
    "start": "sh scripts/rockyd.sh",
    "cli": "npm --prefix vendor/paseo run cli --silent --",
    "build:webui": "npm --prefix vendor/paseo/packages/app run build:web",
    "build:dmg": "npm --prefix vendor/paseo/packages/desktop run build",
    "icons": "python3 scripts/brand/make-icons.py vendor/paseo/packages/desktop/assets",
    "smoke": "sh scripts/smoke.sh"
  },
  "dependencies": {
    "serve-handler": "6.1.6"
  }
}
